  "python_compat": {
    "description": "Python parsing helpers for bolus commands",
    "parse_set_insulin_schedule": "def parse_bolus_schedule(data: bytes) -> dict:\n    \"\"\"Parse SetInsulinScheduleCommand for bolus.\"\"\"\n    if len(data) < 14 or data[0] != 0x1a:\n        raise ValueError('Invalid SetInsulinScheduleCommand')\n    \n    length = data[1]\n    nonce = int.from_bytes(data[2:6], 'big')\n    \n    if data[6] != 0x02:\n        raise ValueError('Not a bolus delivery type')\n    \n    checksum = int.from_bytes(data[7:9], 'big')\n    half_hour_count = data[9]\n    immediate_pulses_x10 = int.from_bytes(data[10:12], 'big')\n    immediate_pulses = int.from_bytes(data[12:14], 'big')\n    \n    # Parse table entries (2 bytes each)\n    entries = []\n    idx = 14\n    while idx + 1 < len(data):\n        entry = int.from_bytes(data[idx:idx+2], 'big')\n        segments = (entry >> 12) & 0xF\n        alternate = bool((entry >> 11) & 1)\n        pulses = entry & 0x7FF\n        entries.append({'segments': segments, 'alternate': alternate, 'pulses': pulses})\n        idx += 2\n    \n    return {\n        'nonce': hex(nonce),\n        'checksum': hex(checksum),\n        'halfHourCount': half_hour_count,\n        'immediateUnits': immediate_pulses * 0.05,\n        'immediatePulses': immediate_pulses,\n        'tableEntries': entries\n    }",
    "parse_bolus_extra": "def parse_bolus_extra(data: bytes) -> dict:\n    \"\"\"Parse BolusExtraCommand.\"\"\"\n    if len(data) != 15 or data[0] != 0x17 or data[1] != 0x0d:\n        raise ValueError('Invalid BolusExtraCommand')\n    \n    beep_flags = data[2]\n    reminder_interval = data[3]\n    immediate_pulses_x10 = int.from_bytes(data[4:6], 'big')\n    time_between_pulses = int.from_bytes(data[6:10], 'big')  # 0.1µs units\n    extended_pulses_x10 = int.from_bytes(data[10:12], 'big')\n    extended_duration = int.from_bytes(data[12:16], 'big')  # 0.1µs units\n    \n    return {\n        'acknowledgementBeep': bool(beep_flags & 0x40),\n        'completionBeep': bool(beep_flags & 0x04),\n        'programReminderInterval': reminder_interval,\n        'immediateUnits': immediate_pulses_x10 / 200,\n        'timeBetweenPulsesSeconds': time_between_pulses / 10_000_000,\n        'extendedUnits': extended_pulses_x10 / 200,\n        'extendedDurationHours': extended_duration / 36_000_000_000\n    }"
  }
