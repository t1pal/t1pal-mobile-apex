{
  "_source": "OmniKit BolusTests.swift (Loop/Trio)",
  "_task": "EROS-SYNTH-004",
  "_description": "Test vectors for OmniPod Eros bolus commands (SetInsulinScheduleCommand + BolusExtraCommand)",
  "_format": {
    "SetInsulinScheduleCommand": {
      "typeRaw": "0x1a",
      "structure": "1a LL NNNNNNNN 02 CCCC HH SSSS PPPP [napp entries...]",
      "fields": {
        "LL": "length (1 byte)",
        "NNNNNNNN": "nonce (4 bytes big-endian)",
        "02": "bolus delivery type marker",
        "CCCC": "checksum (2 bytes)",
        "HH": "half-hour entry count",
        "SSSS": "immediate pulses * 10 (hundredths of units)",
        "PPPP": "immediate pulses",
        "napp": "n=segments, a=alternateSegmentPulse, pp=pulses"
      }
    },
    "BolusExtraCommand": {
      "typeRaw": "0x17",
      "structure": "17 LL BO NNNN XXXXXXXX YYYY ZZZZZZZZ",
      "fields": {
        "LL": "length (always 0x0d = 13)",
        "B": "beep flags (0x40=ack, 0x04=completion)",
        "O": "program reminder interval (0=none, 0x3c=60min)",
        "NNNN": "immediate pulses * 10",
        "XXXXXXXX": "time between pulses in 0.1µs units",
        "YYYY": "extended pulses * 10",
        "ZZZZZZZZ": "extended duration in 0.1µs units"
      }
    },
    "constants": {
      "pulseSize": 0.05,
      "secondsPerBolusPulse": 2,
      "secondsPerPrimePulse": 1,
      "primeUnits": 2.6,
      "cannulaInsertionUnits": 0.5
    }
  },
