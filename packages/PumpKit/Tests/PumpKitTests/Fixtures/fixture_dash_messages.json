  "python_compat": {
    "description": "Python parsing logic for Omnipod messages",
    "code": "import struct\n\ndef parse_message(data: bytes) -> dict:\n    if len(data) < 6:\n        return None\n    address = struct.unpack('>I', data[0:4])[0]\n    control = data[4]\n    sequence_num = (control >> 2) & 0x1f\n    length = data[5]\n    return {\n        'address': address,\n        'sequence_num': sequence_num,\n        'length': length,\n        'blocks_data': data[6:6+length].hex()\n    }\n\ndef parse_message_block(data: bytes) -> dict:\n    if len(data) < 2:\n        return None\n    block_type = data[0]\n    length = data[1]\n    return {\n        'block_type': hex(block_type),\n        'length': length,\n        'payload': data[2:2+length].hex() if len(data) > 2 else ''\n    }\n\ndef parse_status_response(data: bytes) -> dict:\n    # Block type 0x1d\n    if len(data) < 10 or data[0] != 0x1d:\n        return None\n    # Status response format from OmniBLE StatusResponse.swift\n    byte1 = data[2]\n    byte2 = data[3]\n    byte3 = data[4]\n    byte4 = data[5]\n    byte5 = data[6]\n    byte6 = data[7]\n    byte7 = data[8]\n    return {\n        'block_type': '0x1d',\n        'delivery_status': byte1 >> 4,\n        'pod_progress_status': byte1 & 0x0f,\n        'raw_bytes': data[2:].hex()\n    }",
    "notes": "Basic parsing - full implementation requires MessageBlock subclass handling"
  },
