{
  "test_name": "dash_message_parsing",
  "description": "DASH-SYNTH-003: Test vectors for Omnipod DASH/Eros message parsing and encoding",
  "reference": "OmniBLE/OmnipodCommon/Message.swift, OmniBLETests/MessageTests.swift, OmniBLETests/Driver/Comm/message/MessagePacketTests.swift",
  "protocol": {
    "message_format": {
      "description": "Omnipod message structure",
      "fields": "[address:4][control:1][length:1][messageBlocks...][CRC16:2]",
      "control_byte": "sequenceNum (bits 2-6) + type flags",
      "crc": "CRC16-CCITT over all bytes except CRC itself"
    },
    "message_packet_format": {
      "description": "BLE transport layer for DASH",
      "header_size": 16,
      "fields": "type + source + destination + sequenceNumber + ackNumber + flags + payload"
    }
  },
  "message_block_types": {
    "0x01": "VersionResponse",
    "0x03": "SetupPodCommand",
    "0x07": "AssignAddressCommand",
    "0x0e": "GetStatusCommand",
    "0x19": "ConfigureAlertsCommand",
    "0x1a": "SetInsulinScheduleCommand",
    "0x1d": "StatusResponse"
  },
