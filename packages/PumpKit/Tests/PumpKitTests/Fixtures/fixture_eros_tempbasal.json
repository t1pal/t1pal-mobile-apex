{
  "_source": "OmniKit TempBasalTests.swift (Loop/Trio)",
  "_task": "EROS-SYNTH-005",
  "_description": "Test vectors for OmniPod Eros temp basal commands (SetInsulinScheduleCommand + TempBasalExtraCommand)",
  "_format": {
    "SetInsulinScheduleCommand": {
      "typeRaw": "0x1a",
      "structure": "1a LL NNNNNNNN 01 CCCC HH SSSS PPPP [entries...]",
      "fields": {
        "LL": "length (1 byte)",
        "NNNNNNNN": "nonce (4 bytes big-endian)",
        "01": "temp basal delivery type marker",
        "CCCC": "checksum (2 bytes)",
        "HH": "half-hour segment count",
        "SSSS": "seconds remaining << 3 (2 bytes, shifted left 3 bits)",
        "PPPP": "first segment pulses (2 bytes)",
        "entries": "InsulinTableEntry (2 bytes each): n=segments, a=alternateSegmentPulse, pp=pulses"
      }
    },
    "TempBasalExtraCommand": {
      "typeRaw": "0x16",
      "structure": "16 LL RR MM NNNN XXXXXXXX [YYYY ZZZZZZZZ]...",
      "fields": {
        "LL": "length (1 byte)",
        "RR": "beep options ((ack<<7) | (completion<<6) | (reminderMinutes & 0x3f))",
        "MM": "reserved (always 0x00)",
        "NNNN": "remaining pulses * 10 (2 bytes big-endian)",
        "XXXXXXXX": "delay until first pulse in 0.01ms units (4 bytes big-endian)",
        "YYYY": "total pulses * 10 for entry (2 bytes big-endian)",
        "ZZZZZZZZ": "delay between pulses in 0.01ms units (4 bytes big-endian)"
      }
    },
    "CancelDeliveryCommand": {
      "typeRaw": "0x1f",
      "structure": "1f LL NNNNNNNN TT",
      "fields": {
        "LL": "length (always 0x05)",
        "NNNNNNNN": "nonce (4 bytes big-endian)",
        "TT": "delivery type + beep type (0x02=tempBasal, 0x60=beeeeeep)"
      }
    },
    "constants": {
      "pulseSize": 0.05,
      "pulsesPerUnit": 20,
      "zeroBasalDelayHours": 5,
      "zeroBasalDelayMs": 18000000,
      "tempBasalTypeMarker": "0x01"
    }
  },
