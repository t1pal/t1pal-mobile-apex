  "python_compat": {
    "description": "Python parsing helpers for temp basal commands",
    "parse_set_insulin_schedule_tempbasal": "def parse_tempbasal_schedule(data: bytes) -> dict:\n    \"\"\"Parse SetInsulinScheduleCommand for temp basal.\"\"\"\n    if len(data) < 14 or data[0] != 0x1a:\n        raise ValueError('Invalid SetInsulinScheduleCommand')\n    \n    length = data[1]\n    nonce = int.from_bytes(data[2:6], 'big')\n    \n    if data[6] != 0x01:\n        raise ValueError('Not a temp basal delivery type (expected 0x01)')\n    \n    checksum = int.from_bytes(data[7:9], 'big')\n    half_hour_count = data[9]\n    seconds_remaining = int.from_bytes(data[10:12], 'big') >> 3\n    first_segment_pulses = int.from_bytes(data[12:14], 'big')\n    \n    # Parse table entries (2 bytes each)\n    entries = []\n    idx = 14\n    while idx + 1 < len(data):\n        entry = int.from_bytes(data[idx:idx+2], 'big')\n        segments = (entry >> 12) & 0xF\n        alternate = bool((entry >> 11) & 1)\n        pulses = entry & 0x7FF\n        entries.append({'segments': segments, 'alternate': alternate, 'pulses': pulses})\n        idx += 2\n    \n    return {\n        'nonce': hex(nonce),\n        'checksum': hex(checksum),\n        'halfHourCount': half_hour_count,\n        'secondsRemaining': seconds_remaining,\n        'firstSegmentPulses': first_segment_pulses,\n        'tableEntries': entries\n    }",
    "parse_temp_basal_extra": "def parse_temp_basal_extra(data: bytes) -> dict:\n    \"\"\"Parse TempBasalExtraCommand.\"\"\"\n    if len(data) < 14 or data[0] != 0x16:\n        raise ValueError('Invalid TempBasalExtraCommand')\n    \n    length = data[1]\n    num_entries = (length - 8) // 6\n    \n    beep_options = data[2]\n    ack_beep = bool(beep_options & 0x80)\n    completion_beep = bool(beep_options & 0x40)\n    reminder_interval = beep_options & 0x3f\n    \n    remaining_pulses = int.from_bytes(data[4:6], 'big') / 10.0\n    delay_until_first = int.from_bytes(data[6:10], 'big')  # 0.01ms units\n    \n    entries = []\n    idx = 10\n    for _ in range(num_entries):\n        total_pulses = int.from_bytes(data[idx:idx+2], 'big') / 10.0\n        delay_between = int.from_bytes(data[idx+2:idx+6], 'big')\n        entries.append({'totalPulses': total_pulses, 'delayBetweenPulses': delay_between})\n        idx += 6\n    \n    return {\n        'acknowledgementBeep': ack_beep,\n        'completionBeep': completion_beep,\n        'programReminderInterval': reminder_interval,\n        'remainingPulses': remaining_pulses,\n        'delayUntilFirstPulseMs': delay_until_first,\n        'rateEntries': entries\n    }"
  }
