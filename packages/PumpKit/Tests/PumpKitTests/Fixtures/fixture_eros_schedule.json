  "eros_vs_dash_differences": {
    "description": "Eros pods have different minimum basal rate constraints vs DASH",
    "test723ScheduleImport": {
      "source": "BasalScheduleTests.swift test723ScheduleImport()",
      "notes": "Test covers both Eros and DASH variants based on Pod.zeroBasalRate setting",
      "erosVersion": {
        "description": "Eros version with lowest scheduled basal rate of 0.05 U/hr",
        "hex_schedule": "1a18ee29db980002242d0cd000017800380230070008f807e807",
        "hex_extra": "1320000300a8001e8480002815752a000064044aa20000d201885e6d09ab016e3600",
        "hh": "0x2d",
        "ssss": "0x0cd0",
        "nonce": "0xee29db98"
      },
      "dashVersion": {
        "description": "DASH version supports scheduled zero basal rates",
        "hex_schedule": "1a1c494e532e0002122f0ac00001300000012800380230070008f807e807",
        "hex_extra": "132c0005000f007a12000003eb49d200001415752a000001eb49d2000064044aa20000d201885e6d09ab016e3600",
        "hh": "0x2f",
        "ssss": "0x0ac0",
        "nonce": "0x494e532e"
      },
      "schedule": {
        "entries": [
          {"rate": 0.0, "startTime": 0, "notes": "Eros converts to 0.05"},
          {"rate": 0.03, "startTime": 0.5, "notes": "Rounded to 0.05"},
          {"rate": 0.075, "startTime": 1.5, "notes": "Rounded to 0.05"},
