{
  "_source": "OmniKit BasalScheduleTests.swift (Loop/Trio)",
  "_task": "EROS-SYNTH-007",
  "_description": "Test vectors for OmniPod Eros basal schedule commands (SetInsulinScheduleCommand + BasalScheduleExtraCommand)",
  "_format": {
    "SetInsulinScheduleCommand": {
      "typeRaw": "0x1a",
      "structure": "1a LL NNNNNNNN 00 CCCC HH SSSS PPPP [napp napp...]",
      "fields": {
        "LL": "length (1 byte)",
        "NNNNNNNN": "nonce (4 bytes big-endian)",
        "00": "basal delivery type marker (vs 0x01 for temp basal)",
        "CCCC": "checksum (2 bytes)",
        "HH": "current half-hour segment (0x00 = 00:00-00:30, 0x2f = 23:30-24:00)",
        "SSSS": "seconds remaining in segment << 3 (2 bytes, divided by 8 for actual seconds)",
        "PPPP": "pulses remaining in current segment (2 bytes)",
        "napp": "InsulinTableEntry: n=segments(4 bits), a=alternateSegmentPulse(1 bit), pp=pulses(11 bits)"
      }
    },
    "BasalScheduleExtraCommand": {
      "typeRaw": "0x13",
      "structure": "13 LL RR MM NNNN XXXXXXXX [YYYY ZZZZZZZZ]...",
      "fields": {
        "LL": "length (1 byte)",
        "RR": "beep options ((ack<<7) | (completion<<6) | (reminderMinutes & 0x3f))",
        "MM": "current entry index",
        "NNNN": "remaining pulses * 10 (2 bytes big-endian)",
        "XXXXXXXX": "delay until next tenth of pulse in 0.01ms units (4 bytes big-endian)",
        "YYYY": "total pulses * 10 for entry (2 bytes big-endian)",
        "ZZZZZZZZ": "delay between pulses in 0.01ms units (4 bytes big-endian)"
      }
    },
    "CancelDeliveryCommand": {
      "typeRaw": "0x1f",
      "structure": "1f LL NNNNNNNN TT",
      "fields": {
        "LL": "length (always 0x05)",
        "NNNNNNNN": "nonce (4 bytes big-endian)",
        "TT": "delivery type + beep type (0x01=basal, noBeepCancel)"
      }
    },
    "InsulinTableEntry": {
      "checksum": "sum of all bytes: segments + (pulses >> 8) + segments + ((pulses >> 8) + (alternateSegmentPulse ? 1 : 0))",
      "encoding": "(segments << 12) | (alternateSegmentPulse << 11) | (pulses & 0x7FF)"
    },
    "constants": {
      "pulseSize": 0.05,
      "pulsesPerUnit": 20,
      "segmentDurationMinutes": 30,
      "segmentsPerDay": 48,
      "minBasalRate": 0.05,
      "maxBasalRate": 30.0,
      "basalDeliveryTypeMarker": "0x00"
    }
  },

  "insulin_table_entry_vectors": [
    {
      "id": "entry_checksum_basic",
      "description": "InsulinTableEntry checksum calculation (2 segments, 300 pulses, no alternate)",
      "source": "BasalScheduleTests.swift testInsulinTableEntry()",
      "input": {
        "segments": 2,
        "pulses": 300,
        "alternateSegmentPulse": false
      },
      "expected": {
        "checksum": "0x5a",
        "checksumDecimal": 90,
        "notes": "$01 $2c $01 $2c = 1 + 44 + 1 + 44 = 90"
      }
    },
    {
      "id": "entry_checksum_alternate",
      "description": "InsulinTableEntry checksum with alternate segment pulse",
      "source": "BasalScheduleTests.swift testInsulinTableEntry()",
      "input": {
        "segments": 2,
        "pulses": 260,
        "alternateSegmentPulse": true
      },
      "expected": {
        "checksum": "0x0b",
        "checksumDecimal": 11,
        "notes": "$01 $04 $01 $04 = 1 + 4 + 1 + 5 = 11"
      }
    }
  ],

