    "parse_set_basal_schedule": "def parse_basal_schedule(data: bytes) -> dict:\n    \"\"\"Parse SetInsulinScheduleCommand for basal schedule.\"\"\"\n    if len(data) < 14 or data[0] != 0x1a:\n        raise ValueError('Invalid SetInsulinScheduleCommand')\n    \n    length = data[1]\n    nonce = int.from_bytes(data[2:6], 'big')\n    \n    if data[6] != 0x00:\n        raise ValueError('Not a basal schedule (expected 0x00, got temp basal 0x01)')\n    \n    checksum = int.from_bytes(data[7:9], 'big')\n    current_segment = data[9]  # 0x00-0x2f for 00:00-23:30\n    segment_time = f\"{(current_segment // 2):02d}:{(current_segment % 2) * 30:02d}\"\n    seconds_remaining = int.from_bytes(data[10:12], 'big') >> 3\n    pulses_remaining = int.from_bytes(data[12:14], 'big')\n    \n    # Parse table entries (2 bytes each): napp format\n    entries = []\n    idx = 14\n    while idx + 1 < len(data):\n        entry = int.from_bytes(data[idx:idx+2], 'big')\n        segments = (entry >> 12) & 0xF\n        alternate = bool((entry >> 11) & 1)\n        pulses = entry & 0x7FF\n        entries.append({\n            'segments': segments if segments > 0 else 16,\n            'alternateSegmentPulse': alternate,\n            'pulses': pulses\n        })\n        idx += 2\n    \n    return {\n        'nonce': hex(nonce),\n        'checksum': hex(checksum),\n        'currentSegment': current_segment,\n        'currentSegmentTime': segment_time,\n        'secondsRemaining': seconds_remaining,\n        'pulsesRemaining': pulses_remaining,\n        'tableEntries': entries\n    }",
    "parse_basal_schedule_extra": "def parse_basal_schedule_extra(data: bytes) -> dict:\n    \"\"\"Parse BasalScheduleExtraCommand.\"\"\"\n    if len(data) < 10 or data[0] != 0x13:\n        raise ValueError('Invalid BasalScheduleExtraCommand')\n    \n    length = data[1]\n    beep_options = data[2]\n    ack_beep = bool(beep_options & 0x80)\n    completion_beep = bool(beep_options & 0x40)\n    reminder_interval = beep_options & 0x3f\n    \n    current_entry_index = data[3]\n    remaining_pulses = int.from_bytes(data[4:6], 'big') / 10.0\n    delay_until_next = int.from_bytes(data[6:10], 'big')  # 0.001ms units\n    \n    # Parse rate entries (6 bytes each): YYYY ZZZZZZZZ\n    entries = []\n    idx = 10\n    while idx + 5 < len(data):\n        total_pulses = int.from_bytes(data[idx:idx+2], 'big') / 10.0\n        delay_between = int.from_bytes(data[idx+2:idx+6], 'big')  # 0.001ms units\n        delay_seconds = delay_between / 1000000.0\n        rate = (3600.0 / delay_seconds) * 0.05 if delay_seconds > 0 else 0\n        entries.append({\n            'totalPulses': total_pulses,\n            'delayBetweenPulsesMs': delay_between,\n            'delayBetweenPulsesSeconds': delay_seconds,\n            'rate': round(rate, 2)\n        })\n        idx += 6\n    \n    return {\n        'acknowledgementBeep': ack_beep,\n        'completionBeep': completion_beep,\n        'programReminderInterval': reminder_interval,\n        'currentEntryIndex': current_entry_index,\n        'remainingPulses': remaining_pulses,\n        'delayUntilNextTenthOfPulseMs': delay_until_next,\n        'rateEntries': entries\n    }",
    "calculate_offset": "def calculate_schedule_offset(hh: int, ssss: int) -> float:\n    \"\"\"Calculate schedule offset from HH and SSSS fields.\n    \n    Args:\n        hh: Current half-hour segment (0x00-0x2f)\n        ssss: Seconds remaining << 3\n    \n    Returns:\n        Offset in hours from midnight\n    \"\"\"\n    segment_minutes = (hh + 1) * 30\n    seconds_remaining = ssss / 8\n    offset_minutes = segment_minutes - (seconds_remaining / 60)\n    return offset_minutes / 60"
