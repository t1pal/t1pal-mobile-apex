  "_format": {
    "name": "Eros Message (OmniKit-compatible)",
    "bytes[0-3]": "address (UInt32 big-endian)",
    "byte[4]": "(expectFollowOn << 7) | (sequenceNum << 2) | (bodyLen >> 8)",
