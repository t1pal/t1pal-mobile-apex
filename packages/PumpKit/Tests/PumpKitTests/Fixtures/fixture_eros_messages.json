  "crc16_info": {
    "description": "CRC16 used for message integrity (different from packet CRC8)",
    "algorithm": "CRC-16/XMODEM variant",
    "polynomial": "0x8005",
    "initial": "0x0000",
    "notes": "See CRC16.swift in OmniKit"
  },
  "python_compat": {
    "description": "Python parsing logic for Eros messages",
    "code": "import struct\n\nMESSAGE_BLOCK_TYPES = {\n    0x01: 'VersionResponse',\n    0x02: 'DetailedStatus',\n    0x03: 'SetupPodCommand',\n    0x07: 'AssignAddressCommand',\n    0x0e: 'GetStatusCommand',\n    0x19: 'ConfigureAlertsCommand',\n    0x1a: 'SetInsulinScheduleCommand',\n    0x1c: 'CancelDeliveryCommand',\n    0x1d: 'StatusResponse',\n    0x1e: 'BeepConfigCommand',\n    0x1f: 'DeactivatePodCommand',\n}\n\n# CRC16 table for OmniPod messages\ndef crc16(data: bytes) -> int:\n    \"\"\"Calculate CRC16 for Eros message (XMODEM variant).\"\"\"\n    crc = 0\n    for byte in data:\n        crc ^= byte << 8\n        for _ in range(8):\n            if crc & 0x8000:\n                crc = (crc << 1) ^ 0x8005\n            else:\n                crc <<= 1\n            crc &= 0xFFFF\n    return crc\n\ndef parse_eros_message(data: bytes) -> dict:\n    \"\"\"Parse an Eros message from raw bytes.\"\"\"\n    if len(data) < 10:\n        raise ValueError('Insufficient data for message (need >= 10 bytes)')\n    \n    address = struct.unpack('>I', data[0:4])[0]\n    b9 = data[4]\n    body_len = data[5]\n    \n    expect_follow_on = bool(b9 & 0x80)\n    sequence_num = (b9 >> 2) & 0x0F\n    \n    if body_len > len(data) - 8:\n        raise ValueError(f'Body length {body_len} exceeds available data')\n    \n    # Verify CRC16\n    expected_crc = crc16(data[:-2])\n    actual_crc = struct.unpack('>H', data[-2:])[0]\n    if expected_crc != actual_crc:\n        raise ValueError(f'CRC16 mismatch: expected {expected_crc:#06x}, got {actual_crc:#06x}')\n    \n    # Parse message blocks\n    body = data[6:-2]\n    blocks = []\n    idx = 0\n    while idx < len(body):\n        block_type = body[idx]\n        block_name = MESSAGE_BLOCK_TYPES.get(block_type, f'Unknown(0x{block_type:02x})')\n        \n        # Block length is at offset 1 (varies by block type)\n        if idx + 1 < len(body):\n            block_len = body[idx + 1] + 2  # +2 for type and length bytes\n        else:\n            block_len = len(body) - idx\n        \n        block_data = body[idx:idx + block_len]\n        blocks.append({\n            'type': block_name,\n            'typeRaw': block_type,\n            'data': block_data.hex(),\n            'dataLen': len(block_data)\n        })\n        idx += block_len\n    \n    return {\n        'address': address,\n        'addressHex': f'0x{address:08x}',\n        'sequenceNum': sequence_num,\n        'expectFollowOn': expect_follow_on,\n        'bodyLen': body_len,\n        'messageBlocks': blocks,\n        'crc16': actual_crc,\n        'crc16Hex': f'0x{actual_crc:04x}'\n    }\n\ndef encode_eros_message(address: int, sequence_num: int, blocks_data: bytes,\n                        expect_follow_on: bool = False) -> bytes:\n    \"\"\"Encode an Eros message to raw bytes.\"\"\"\n    # Build message without CRC\n    msg = struct.pack('>I', address)\n    \n    body_len = len(blocks_data)\n    b9 = ((1 if expect_follow_on else 0) << 7) | ((sequence_num & 0x0F) << 2) | ((body_len >> 8) & 0x03)\n    msg += bytes([b9, body_len & 0xFF])\n    msg += blocks_data\n    \n    # Append CRC16\n    msg += struct.pack('>H', crc16(msg))\n    return msg"
  }
