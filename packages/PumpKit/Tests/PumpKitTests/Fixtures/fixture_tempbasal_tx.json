      "opcode": "0x4C",
      "body_hex": "03 00 2C 01",
      "body_length": 3,
      "input_rate": 1.1,
      "input_duration_minutes": 30,
      "strokes_raw": 44,
      "strokes_hex": "00 2C",
      "time_segments": 1,
      "expected_rate": 1.1,
      "expected_duration_minutes": 30,
      "notes": "1.1 U/hr * 40 = 44 strokes (0x002C), 30min / 30 = 1 segment"
    },
    {
