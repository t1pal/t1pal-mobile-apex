      },
      {
        "name": "aggressive",
        "base_delay_ms": 500,
        "max_delay_ms": 10000,
        "max_attempts": 10,
        "multiplier": 1.5,
        "jitter": "full"
      },
      {
        "name": "conservative",
        "base_delay_ms": 2000,
        "max_delay_ms": 120000,
        "max_attempts": 3,
        "multiplier": 3.0,
        "jitter": "equal"
      }
    ],
    "formula": "delay = min(base_delay * (multiplier ^ attempt), max_delay) + jitter"
