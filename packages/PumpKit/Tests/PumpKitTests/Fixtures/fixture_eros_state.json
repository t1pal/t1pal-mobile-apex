{
  "_source": "OmniKit PodStateTests.swift, StatusTests.swift, PodInfoTests.swift (Loop/Trio)",
  "_task": "EROS-SYNTH-006",
  "_description": "Test vectors for Omnipod Eros pod state parsing: nonces, status, detailed status, alerts",
  "_format": {
    "nonce": "32-bit value used for command authentication",
    "status_response": "12 bytes: deliveryStatus, podProgress, timeActive, reservoir, etc.",
    "detailed_status": "21 bytes: faultEventCode, totalInsulinDelivered, errorEventInfo, etc.",
    "triggered_alerts": "19 bytes: alert activation timestamps for slots 0-7"
  },

  "nonce_vectors": [
    {
      "id": "nonce_sequence",
      "description": "Nonce calculation sequence from PodState initialization",
      "source": "PodStateTests.swift testNonceValues()",
      "input": {
        "address": "0x1f000000",
        "lot": 42560,
        "tid": 661771
      },
      "expected_sequence": [
        {"index": 0, "nonce": "0x8c61ee59", "nonceDecimal": 2355760729},
        {"index": 1, "nonce": "0xc0256620", "nonceDecimal": 3224561184},
        {"index": 2, "nonce": "0x15022c8a", "nonceDecimal": 352337034},
        {"index": 3, "nonce": "0xacf076ca", "nonceDecimal": 2901080778}
      ],
      "notes": "Each call to advanceToNextNonce() moves to next value"
    },
    {
      "id": "nonce_resync",
      "description": "Nonce resynchronization after badNonce error",
      "source": "PodStateTests.swift testResyncNonce()",
      "input": {
        "versionResponseHex": "011502070002070002020000a62b0002249da11f00ee860318",
        "lot": 42539,
        "tid": 140445,
        "address": "0x1f00ee86",
        "initialNonce": "0x8fd39264"
      },
      "error_scenario": {
        "sentPacketHex": "1f00ee86ba1f00ee8624061c042e07c7c703c1f4",
        "sentMessageSequenceNum": 9,
        "sentNonce": "0x2e07c7c7",
        "errorResponseHex": "06031492c482f5",
        "errorType": "badNonce",
        "nonceResyncKey": "0x92c4",
        "expectedNonceAfterResync": "0x40ccdacb"
      }
    }
  ],

  "error_response_vectors": [
    {
      "id": "error_nonretryable",
      "description": "Non-retryable error response",
      "source": "PodStateTests.swift testErrorResponse()",
      "hex": "0603070008019a",
      "expected": {
        "errorResponseType": "nonretryableError",
        "errorCode": 7,
        "faultEventCode": "noFaults",
        "podProgress": "aboveFiftyUnits"
      },
      "parsing": {
        "byte0": "0x06 = ErrorResponse type",
        "byte1": "0x03 = length",
        "byte2": "0x07 = errorCode",
        "byte3": "0x00 = faultEventCode (noFaults)",
        "byte4": "0x08 = podProgress (aboveFiftyUnits)",
        "bytes5-6": "0x019a = CRC"
      }
    }
  ],

