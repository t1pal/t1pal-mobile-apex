  "status_response_vectors": [
    {
      "id": "status_46_units_left",
      "description": "StatusResponse with 46 units remaining",
      "source": "StatusTests.swift testStatusResponse46UnitsLeft()",
      "hex": "1d19050ec82c08376f9801dc",
      "expected": {
        "type": "StatusResponse",
        "deliveryStatus": "scheduledBasal",
        "deliveryStatusRaw": 1,
        "podProgressStatus": "fiftyOrLessUnits",
        "podProgressRaw": 9,
        "timeActiveMinutes": 3547,
        "timeActiveFormatted": "59h7m",
        "insulinDelivered": 129.45,
        "reservoirLevel": 46.0,
        "bolusNotDelivered": 2.2,
        "lastProgrammingMessageSeqNum": 9,
        "alerts": []
      },
      "parsing": {
        "byte0": "0x1d = StatusResponse type",
        "byte1": "0x19 = 0b00011001 → deliveryStatus=1, podProgress=9",
        "bytes2-3": "0x050e = timeActive raw (3547 >> 4 = 221.6875... need clarification)",
        "note": "Complex bit packing - see OmniKit StatusResponse.swift"
      }
    }
  ],

