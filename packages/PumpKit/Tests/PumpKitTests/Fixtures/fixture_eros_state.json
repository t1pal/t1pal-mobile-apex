  "python_compat": {
    "description": "Python parsing functions for Eros pod state",
    "code": "import struct\n\n# Pod Progress Status\nPOD_PROGRESS = {\n    0: 'initialized', 1: 'tankPowerActivated', 2: 'tankFillCompleted',\n    3: 'pairingCompleted', 4: 'primingCompleted', 5: 'readyForBasalSchedule',\n    6: 'insertingCannula', 7: 'runningAboveMinVolume', 8: 'aboveFiftyUnits',\n    9: 'fiftyOrLessUnits', 13: 'faultEventOccurred', 14: 'activationTimeExceeded',\n    15: 'inactive'\n}\n\n# Delivery Status\nDELIVERY_STATUS = {\n    0: 'suspended', 1: 'scheduledBasal', 2: 'tempBasal', 3: 'priming',\n    4: 'bolusAndTempBasal', 5: 'bolus', 6: 'bolusAndScheduledBasal'\n}\n\n# Fault Event Codes\nFAULT_CODES = {\n    0: 'noFaults', 18: 'resetDueToLVD', 92: 'primeOpenCountTooLow',\n    106: 'occlusionCheckAboveThreshold', 134: 'basalOverInfusionPulse',\n    143: 'command1AParseUnexpectedFailed', 146: 'tempPulseChanInactive'\n}\n\ndef parse_detailed_status(data: bytes) -> dict:\n    \"\"\"Parse DetailedStatus (0x02) response - 21 bytes.\n    \n    Format: 02 0J 0K LLLL MM NNNN PP QQQQ RRRR SSSS TT UU VV WW 0X YYYY\n    \"\"\"\n    if len(data) < 21 or data[0] != 0x02:\n        raise ValueError('Invalid DetailedStatus data')\n    \n    pod_progress = (data[1] >> 4) & 0x0F\n    delivery_status = data[1] & 0x0F\n    bolus_not_delivered_raw = (data[2] << 8 | data[3])\n    bolus_not_delivered = bolus_not_delivered_raw * 0.05  # pulses to units\n    last_seq = data[4]\n    total_delivered_raw = (data[5] << 8 | data[6])\n    total_delivered = total_delivered_raw * 0.05\n    fault_code = data[7]\n    fault_time_raw = (data[8] << 8 | data[9])\n    fault_time = None if fault_time_raw == 0xFFFF else fault_time_raw\n    reservoir_raw = (data[10] << 8 | data[11])\n    reservoir = 51.15 if reservoir_raw >= 1023 else reservoir_raw * 0.05\n    time_active = (data[12] << 8 | data[13])\n    alerts = data[14]\n    fault_access = bool(data[15] & 0x02)\n    \n    # Error event info (byte 16-17)\n    error_info = None\n    if data[16] != 0x00 or data[17] != 0x00:\n        error_info = {\n            'insulinStateTableCorruption': bool(data[16] & 0x80),\n            'occlusionType': (data[16] >> 5) & 0x03,\n            'immediateBolusInProgress': bool(data[16] & 0x10),\n            'podProgressStatus': POD_PROGRESS.get(data[16] & 0x0F, f'unknown({data[16] & 0x0F})')\n        }\n    \n    receiver_gain = (data[17] >> 6) & 0x03\n    rssi = data[17] & 0x3F\n    previous_progress = None if data[18] == 0xFF else POD_PROGRESS.get(data[18] & 0x0F)\n    \n    return {\n        'podProgressStatus': POD_PROGRESS.get(pod_progress, f'unknown({pod_progress})'),\n        'deliveryStatus': DELIVERY_STATUS.get(delivery_status, f'unknown({delivery_status})'),\n        'bolusNotDelivered': bolus_not_delivered,\n        'lastProgrammingMessageSeqNum': last_seq,\n        'totalInsulinDelivered': total_delivered,\n        'faultEventCode': FAULT_CODES.get(fault_code, f'unknown(0x{fault_code:02x})'),\n        'faultEventTimeSinceActivation': fault_time,\n        'reservoirLevel': reservoir,\n        'timeActiveMinutes': time_active,\n        'unacknowledgedAlerts': alerts,\n        'faultAccessingTables': fault_access,\n        'errorEventInfo': error_info,\n        'receiverLowGain': receiver_gain,\n        'radioRSSI': rssi,\n        'previousPodProgressStatus': previous_progress\n    }\n\ndef parse_status_response(data: bytes) -> dict:\n    \"\"\"Parse StatusResponse (0x1d) - 10 bytes.\"\"\"\n    if len(data) < 10 or data[0] != 0x1d:\n        raise ValueError('Invalid StatusResponse data')\n    \n    # Complex bit-packed format - see OmniKit StatusResponse.swift\n    # This is a simplified version\n    return {\n        'type': 'StatusResponse',\n        'raw': data.hex()\n    }\n"
  }
