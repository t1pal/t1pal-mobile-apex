  "rejection_scenarios": [
    {
      "scenario_id": "REJECT-001",
      "name": "Pod already paired",
      "description": "Attempting to pair with a pod that's already paired to another device",
      "trigger_state": "pairing",
      "fault_type": "pairingAlreadyPaired",
      "error": {
        "type": "PumpError.podAlreadyPaired",
        "message": "Pod is already paired to another device",
        "recoverable": false
      },
      "expected_behavior": {
        "state_transition": "pairing → error",
        "callback": "onPairingRejected(reason: .alreadyPaired)",
        "user_action_required": "Use different pod or reset pairing on original device"
      },
      "test_setup": {
        "mock_action": "Return pairing rejected response"
      }
    },
    {
      "scenario_id": "REJECT-002",
      "name": "Pod expired",
      "description": "Pod has exceeded 72-hour maximum life",
      "trigger_state": "connected",
      "fault_type": "podExpired",
      "fault_code": "0x1C",
      "rx_message": {
        "command": "StatusResponse (0x1d)",
        "pod_progress_status": "expired"
      },
      "error": {
        "type": "PumpError.podExpired",
        "message": "Pod has expired (72 hour limit exceeded)",
        "recoverable": false
      },
      "expected_behavior": {
        "state_transition": "connected → deactivating",
        "callback": "onPodExpired()",
        "user_action_required": "Deactivate and replace pod"
      },
      "test_setup": {
        "mock_action": "Return StatusResponse with expired pod progress"
      }
    },
    {
