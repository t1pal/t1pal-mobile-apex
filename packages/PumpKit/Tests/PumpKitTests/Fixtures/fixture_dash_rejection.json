  "test_vectors": [
    {
      "name": "Fault code parsing",
      "input_hex": "1d28008200004446ebff",
      "expected": {
        "is_status_response": true,
        "has_fault": true,
        "fault_code": "0x14"
      }
    },
    {
      "name": "Pod progress state extraction",
      "status_response_hex": "1f00ee84300a1d18003f1800004297ff8128",
      "expected": {
        "pod_progress_status": "aboveFiftyUnits",
        "can_communicate": true
      }
    },
    {
      "name": "Occlusion alarm handling sequence",
      "scenario": "REJECT-003",
      "callback_sequence": [
        "onStatusReceived(status)",
        "onFaultDetected(fault: .occlusion)",
        "onPodAlarm(fault: .occlusion)",
        "notifyUser(alarm: .occlusion)"
      ]
    }
  ],

  "recovery_patterns": {
    "occlusion": {
      "steps": [
        "Stop all delivery (already stopped by pod)",
        "Acknowledge alarm if possible",
        "Guide user to deactivate pod",
        "Assist with new pod activation"
      ],
      "can_silence": false
    },
    "ble_nack": {
      "steps": [
        "Log NACK reason",
        "Reset BLE sequence number",
        "Retry command",
        "If persistent, disconnect and reconnect"
      ],
      "can_retry": true
    },
    "authentication_failed": {
      "steps": [
        "Disconnect BLE",
        "Clear session state",
        "Retry pairing from beginning"
      ],
      "can_retry": true
    }
  }
}
