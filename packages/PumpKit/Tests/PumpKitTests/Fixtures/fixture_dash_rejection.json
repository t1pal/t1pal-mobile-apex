      "fault_type": "occlusion",
      "fault_code": "0x14",
      "rx_message": {
        "command": "StatusResponse (0x1d)",
        "alerts": ["slot5Immediate"],
        "fault_event_code": "0x14"
      },
      "error": {
        "type": "PumpError.occlusion",
        "message": "Occlusion detected - check infusion site",
        "is_alarm": true,
        "recoverable": false
