{
  "session_id": "SESSION-G7-TIMEOUT-001",
  "session_name": "Dexcom G7 Timeout Scenarios",
  "description": "Synthesized timeout conditions for G7 BLE connection flow. Used for testing retry logic and timeout handling.",
  "source": "Synthesized from fixture_g7_connect.json timing specifications",
  "schema_version": "2.0.0",
  "hardware_validated": false,
  "trace": "G7-FIX-014",
