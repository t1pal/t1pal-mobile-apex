  "python_compat": {
    "description": "Python implementation for cross-validation",
    "key_constant": "KEY = [0xA0C5, 0x6860, 0x0000, 0x14C6]",
    "process_crypto": [
      "def op(value, key):",
      "    res = value >> 2",
      "    if value & 1: res ^= key[1]",
      "    if value & 2: res ^= key[0]",
      "    return res & 0xFFFF",
      "",
      "def process_crypto(inp, key=KEY):",
      "    r0 = op(inp[0], key) ^ inp[3]",
      "    r1 = op(r0, key) ^ inp[2]",
      "    r2 = op(r1, key) ^ inp[1]",
      "    r3 = op(r2, key) ^ inp[0]",
      "    r4 = op(r3, key)",
      "    r5 = op(r4 ^ r0, key)",
      "    r6 = op(r5 ^ r1, key)",
      "    r7 = op(r6 ^ r2, key)",
      "    return [r3 ^ r7, r2 ^ r6, r1 ^ r5, r0 ^ r4]"
    ],
    "prepare_variables": [
      "def prepare_variables(sensor_id, x, y, key=KEY):",
      "    s1 = (sensor_id[5] << 8 | sensor_id[4]) + x + y",
      "    s2 = (sensor_id[3] << 8 | sensor_id[2]) + key[2]",
      "    s3 = (sensor_id[1] << 8 | sensor_id[0]) + x * 2",
      "    s4 = 0x241a ^ key[3]",
      "    return [s1 & 0xFFFF, s2 & 0xFFFF, s3 & 0xFFFF, s4 & 0xFFFF]"
    ],
    "useful_function": [
      "def useful_function(sensor_id, x, y):",
      "    block_key = process_crypto(prepare_variables(sensor_id, x, y))",
      "    r1 = block_key[0] ^ 0x4163",
      "    r2 = block_key[1] ^ 0x4344",
      "    return [r1 & 0xFF, (r1 >> 8) & 0xFF, r2 & 0xFF, (r2 >> 8) & 0xFF]"
    ]
  }
