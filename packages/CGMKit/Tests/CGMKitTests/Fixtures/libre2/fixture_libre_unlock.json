      "id": "processCrypto_basic",
      "description": "Test processCrypto with known input",
      "function": "processCrypto",
      "source_line": 129,
      "algorithm": [
        "op(value) = (value >> 2) ^ (key[1] if bit0) ^ (key[0] if bit1)",
        "r0 = op(input[0]) ^ input[3]",
        "r1 = op(r0) ^ input[2]",
        "r2 = op(r1) ^ input[1]",
        "r3 = op(r2) ^ input[0]",
        "r4 = op(r3)",
        "r5 = op(r4 ^ r0)",
        "r6 = op(r5 ^ r1)",
        "r7 = op(r6 ^ r2)",
        "return [r3^r7, r2^r6, r1^r5, r0^r4]"
      ],
      "notes": "Custom cipher based on bit manipulation and XOR with key constants"
    },
    {
      "id": "prepareVariables_block",
