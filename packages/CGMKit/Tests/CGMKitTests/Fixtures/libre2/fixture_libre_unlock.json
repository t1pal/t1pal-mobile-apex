      "description": "Structure of 12-byte streaming unlock payload",
      "function": "streamingUnlockPayload",
      "source_line": 98,
      "inputParameters": {
        "sensorUID": "8-byte sensor UID from NFC",
        "info": "6-byte patch info from NFC command 0xA1",
        "enableTime": "UInt32 timestamp when streaming was enabled",
        "unlockCount": "UInt16 counter incremented each unlock"
      },
      "outputStructure": {
        "bytes_0_3": "time = enableTime + unlockCount (little-endian UInt32)",
        "bytes_4_11": "8-byte crypto result from processCrypto chain"
      },
      "algorithm": [
        "time = enableTime + unlockCount",
        "b[0..3] = little-endian bytes of time",
        "ad = usefulFunction(sensorUID, 0x1b, 0x1b6a)",
        "ed = usefulFunction(sensorUID, 0x1e, (enableTime & 0xFFFF) ^ UInt16(info[5], info[4]))",
        "t11 = UInt16(ed[1], ed[0]) ^ UInt16(b[3], b[2])",
        "t12 = UInt16(ad[1], ad[0])",
        "t13 = UInt16(ed[3], ed[2]) ^ UInt16(b[1], b[0])",
        "t14 = UInt16(ad[3], ad[2])",
        "t2 = processCrypto(prepareVariables(sensorUID, t11, t12, t13, t14))",
        "t31 = crc16([0xc1,0xc4,0xc3,0xc0,0xd4,0xe1,0xe7,0xba, t2[0].lo, t2[0].hi]).byteSwapped",
        "t32 = crc16([t2[1].lo, t2[1].hi, t2[2].lo, t2[2].hi, t2[3].lo, t2[3].hi]).byteSwapped",
        "t33 = crc16([ad[0], ad[1], ad[2], ad[3], ed[0], ed[1]]).byteSwapped",
        "t34 = crc16([ed[2], ed[3], b[0], b[1], b[2], b[3]]).byteSwapped",
        "t4 = processCrypto(prepareVariables(sensorUID, t31, t32, t33, t34))",
        "return [b[0], b[1], b[2], b[3], t4[0..3] as bytes]"
      ],
      "crc16_magic_bytes": [193, 196, 195, 192, 212, 225, 231, 186],
      "crc16_magic_hex": "c1c4c3c0d4e1e7ba"
    }
