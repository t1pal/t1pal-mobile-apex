  "python_compat": {
    "description": "Python implementation for cross-validation",
    "aes_ccm_decrypt": [
      "from Crypto.Cipher import AES",
      "",
      "def aes_ccm_decrypt(key: bytes, nonce: bytes, ciphertext: bytes, aad: bytes, tag_length: int) -> bytes:",
      "    # Note: pycryptodome's CCM expects ciphertext without tag",
      "    # Tag is appended to ciphertext in the test vectors",
      "    cipher = AES.new(key, AES.MODE_CCM, nonce=nonce, mac_len=tag_length)",
      "    cipher.update(aad)",
      "    msg_len = len(ciphertext) - tag_length",
      "    tag = ciphertext[msg_len:]",
      "    plaintext = cipher.decrypt_and_verify(ciphertext[:msg_len], tag)",
      "    return plaintext"
    ],
    "aes_128_ecb_encrypt": [
      "from Crypto.Cipher import AES",
      "from Crypto.Util.Padding import pad",
      "",
      "def aes_128_ecb_encrypt(key: bytes, plaintext: bytes) -> bytes:",
      "    cipher = AES.new(key, AES.MODE_ECB)",
      "    padded = pad(plaintext, AES.block_size, style='pkcs7')",
      "    return cipher.encrypt(padded)"
    ],
    "test_vector_validation": [
