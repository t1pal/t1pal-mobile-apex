  "protocol_overview": {
    "name": "J-PAKE (RFC 8236)",
    "curve": "P-256 (secp256r1)",
    "password": "4-digit sensor code",
    "purpose": "Password-authenticated key exchange without exposing the password"
  },

  "round1_format": {
    "description": "Round 1 exchanges public keys and zero-knowledge proofs",
    "opcode": "0x02",
    "opcode_name": "AuthRound1",
    "direction": "bidirectional",
    "initiator_message": {
      "format": "[opcode:1] + [gx1:32] + [gx2:32] + [zkp1:80] + [zkp2:80]",
      "total_length": 225,
      "fields": {
        "opcode": { "offset": 0, "length": 1, "value": "0x02" },
        "gx1": { "offset": 1, "length": 32, "description": "First public key g^x1 (P-256 X coordinate)" },
        "gx2": { "offset": 33, "length": 32, "description": "Second public key g^x2 (P-256 X coordinate)" },
        "zkp1": { "offset": 65, "length": 80, "description": "Zero-knowledge proof for x1" },
        "zkp2": { "offset": 145, "length": 80, "description": "Zero-knowledge proof for x2" }
      }
    },
    "responder_message": {
      "format": "[opcode:1] + [gx3:32] + [gx4:32] + [zkp3:80] + [zkp4:80]",
      "total_length": 225,
      "fields": {
        "opcode": { "offset": 0, "length": 1, "value": "0x02" },
        "gx3": { "offset": 1, "length": 32, "description": "Sensor public key g^x3" },
        "gx4": { "offset": 33, "length": 32, "description": "Sensor public key g^x4" },
        "zkp3": { "offset": 65, "length": 80, "description": "Zero-knowledge proof for x3" },
        "zkp4": { "offset": 145, "length": 80, "description": "Zero-knowledge proof for x4" }
      }
    }
  },

  "zkp_structure": {
    "name": "Schnorr Zero-Knowledge Proof",
    "description": "Proves knowledge of discrete log x such that Y = g^x without revealing x",
    "total_length": 80,
    "fields": {
      "commitment": {
        "offset": 0,
        "length": 32,
        "description": "V = g^v where v is random nonce (Schnorr commitment)"
      },
      "challenge": {
        "offset": 32,
        "length": 16,
        "description": "c = H(G, Y, V, party_id)[0:16] truncated hash"
      },
      "response": {
        "offset": 48,
        "length": 32,
        "description": "r = v - c*x mod n (Schnorr response)"
      }
    },
    "verification": {
      "algorithm": "g^r * Y^c == V",
      "hash_input": "party_id || Y || V",
      "curve_order": "0xFFFFFFFF00000000FFFFFFFFFFFFFFFFBCE6FAADA7179E84F3B9CAC2FC632551"
    }
  },

  "p256_constants": {
    "curve_name": "secp256r1 / P-256 / prime256v1",
    "field_size": 32,
    "uncompressed_point_size": 65,
    "compressed_point_size": 33,
    "packet_size": 160,
    "curve_order_hex": "FFFFFFFF00000000FFFFFFFFFFFFFFFFBCE6FAADA7179E84F3B9CAC2FC632551",
    "curve_order_bytes": [
      255, 255, 255, 255, 0, 0, 0, 0,
      255, 255, 255, 255, 255, 255, 255, 255,
      188, 230, 250, 173, 167, 23, 158, 132,
      243, 185, 202, 194, 252, 99, 37, 81
    ]
  },

  "test_vectors": [
    {
      "id": "JPAKE-R1-001",
      "name": "Round 1 message structure validation",
      "description": "Verify Round 1 message has correct size and opcode",
      "assertions": [
        { "field": "message.data[0]", "equals": "0x02", "reason": "AuthRound1 opcode" },
        { "field": "message.data.count", "equals": 225, "reason": "opcode(1) + gx1(32) + gx2(32) + zkp1(80) + zkp2(80)" },
        { "field": "gx1.count", "equals": 32, "reason": "P-256 X coordinate" },
        { "field": "gx2.count", "equals": 32, "reason": "P-256 X coordinate" }
      ]
    },
    {
      "id": "JPAKE-R1-002",
      "name": "ZKP structure validation",
      "description": "Verify zero-knowledge proof has correct component sizes",
      "assertions": [
        { "field": "zkp.commitment.count", "equals": 32, "reason": "EC point X coordinate" },
        { "field": "zkp.challenge.count", "equals": 16, "reason": "Truncated hash" },
        { "field": "zkp.response.count", "equals": 32, "reason": "Scalar mod n" },
        { "field": "zkp.data.count", "equals": 80, "reason": "Total ZKP size" }
      ]
    },
    {
      "id": "JPAKE-R1-003",
      "name": "Public key randomness",
      "description": "Consecutive Round 1 messages should have different public keys",
      "assertions": [
        { "field": "round1a.gx1", "not_equals": "round1b.gx1", "reason": "Random x1 values" },
        { "field": "round1a.gx2", "not_equals": "round1b.gx2", "reason": "Random x2 values" }
      ]
    },
    {
      "id": "JPAKE-R1-004",
      "name": "Round 1 response parsing",
      "description": "Parse sensor's Round 1 response correctly",
      "input_structure": {
        "opcode": "0x02",
        "gx3_length": 32,
        "gx4_length": 32,
        "zkp3_length": 80,
        "zkp4_length": 80
      },
      "assertions": [
        { "condition": "response != nil", "when": "data.count >= 225" },
        { "condition": "response == nil", "when": "data[0] != 0x02" },
        { "condition": "response == nil", "when": "data.count < 225" }
      ]
    },
    {
      "id": "JPAKE-R1-005",
      "name": "ZKP parsing from data",
      "description": "Parse zero-knowledge proof from 80-byte data",
      "sample_zkp_hex": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaabbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbcccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc",
      "expected": {
        "commitment_hex": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
        "challenge_hex": "bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb",
        "response_hex": "cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc"
      }
    },
    {
      "id": "JPAKE-R1-006",
      "name": "Key pair generation produces valid EC points",
