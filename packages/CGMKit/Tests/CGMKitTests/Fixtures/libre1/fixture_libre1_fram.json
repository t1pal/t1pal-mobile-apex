  },

  "sensor_states": {
    "0x00": "unknown",
    "0x01": "notActivated",
    "0x02": "warmingUp",
    "0x03": "active",
    "0x04": "expired",
    "0x05": "shutdown",
    "0x06": "failure"
  },

  "sensor_regions": {
    "0x00": "unknown",
    "0x01": "european",
    "0x02": "usa",
    "0x04": "australianCanadian",
    "0x08": "easternROW"
  },

  "fram_structure": {
    "header": {
      "offset": 0,
      "size": 24,
      "fields": {
        "crc16": "bytes[0-1] - CRC16 of bytes[2-23]",
        "reserved": "bytes[2-3]",
        "state": "byte[4] - SensorState enum",
        "reserved2": "byte[5]",
        "failureErrorCode": "byte[6] - if state=failure",
        "failureAge": "bytes[7-8] - minutes since activation when failure occurred",
        "reserved3": "bytes[9-23] - all zeros for Libre 1"
      }
    },
    "body": {
      "offset": 24,
      "size": 296,
      "fields": {
        "crc16": "bytes[0-1] - CRC16 of bytes[2-295]",
        "trendIndex": "byte[2] - next trend slot to write (0-15)",
        "historyIndex": "byte[3] - next history slot to write (0-31)",
        "trendData": "bytes[4-99] - 16 trend readings × 6 bytes each",
        "historyData": "bytes[100-291] - 32 history readings × 6 bytes each",
        "age": "bytes[292-293] - minutes since sensor activation (LE)",
        "initializations": "byte[294] - number of times sensor was initialized"
      }
    },
    "footer": {
      "offset": 320,
      "size": 24,
      "fields": {
        "crc16": "bytes[0-1] - CRC16 of bytes[2-23]",
        "region": "byte[3] - SensorRegion enum",
        "maxLife": "bytes[6-7] - max sensor life in minutes (LE)",
        "calibrationInfo": "bytes[8-15] - factory calibration data"
      }
    }
  },

  "glucose_record_format": {
    "size": 6,
    "fields": {
      "rawValue": "bits[0-13] (14 bits) - raw glucose value",
      "quality": "bits[14-24] (11 bits) - lower 9 bits = quality flags, upper 2 = qualityFlags",
      "hasError": "bit[25] (1 bit) - error flag",
      "rawTemperature": "bits[26-37] (12 bits) - raw temperature << 2",
      "temperatureAdjustment": "bits[38-46] (9 bits) - adjustment << 2",
      "negativeAdjustment": "bit[47] (1 bit) - if set, temperatureAdjustment is negative"
    }
  },

