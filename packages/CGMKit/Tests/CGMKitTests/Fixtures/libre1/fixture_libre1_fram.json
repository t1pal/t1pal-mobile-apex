  "python_compat": {
    "description": "Python parsing logic for Libre 1 FRAM",
    "code": "import struct\n\ndef read_bits(buffer: bytes, byte_offset: int, bit_offset: int, bit_count: int) -> int:\n    \"\"\"Read bits from buffer (DiaBLE-compatible)\"\"\"\n    result = 0\n    for i in range(bit_count):\n        total_bit = byte_offset * 8 + bit_offset + i\n        byte_idx = total_bit // 8\n        bit_idx = total_bit % 8\n        if byte_idx < len(buffer) and ((buffer[byte_idx] >> bit_idx) & 1) == 1:\n            result |= 1 << i\n    return result\n\ndef parse_libre1_glucose_record(data: bytes, offset: int) -> dict:\n    \"\"\"Parse a 6-byte glucose record from FRAM\"\"\"\n    raw_value = read_bits(data, offset, 0, 14)\n    quality = read_bits(data, offset, 14, 11) & 0x1FF\n    quality_flags = (read_bits(data, offset, 14, 11) & 0x600) >> 9\n    has_error = read_bits(data, offset, 25, 1) != 0\n    raw_temp = read_bits(data, offset, 26, 12) << 2\n    temp_adj = read_bits(data, offset, 38, 9) << 2\n    neg_adj = read_bits(data, offset, 47, 1) != 0\n    if neg_adj:\n        temp_adj = -temp_adj\n    return {\n        'rawValue': raw_value,\n        'quality': quality,\n        'qualityFlags': quality_flags,\n        'hasError': has_error,\n        'rawTemperature': raw_temp,\n        'temperatureAdjustment': temp_adj\n    }\n\ndef parse_libre1_fram(data: bytes) -> dict:\n    \"\"\"Parse 344-byte Libre 1 FRAM\"\"\"\n    if len(data) < 344:\n        return None\n    state = data[4]\n    trend_idx = data[26]\n    history_idx = data[27]\n    age = data[316] | (data[317] << 8)\n    max_life = data[326] | (data[327] << 8)\n    region = data[323]\n    return {\n        'state': state,\n        'trendIndex': trend_idx,\n        'historyIndex': history_idx,\n        'age': age,\n        'maxLife': max_life,\n        'region': region\n    }"
  }
