  "password_to_scalar_tests": [
    {
      "id": "PTS-001",
      "description": "ScalarOperations.passwordToScalar - 4 digit",
      "password": "1234",
      "expected_hex": "31323334",
      "expected_bytes": [49, 50, 51, 52],
      "_note": "Raw bytes without padding - matches Swift passwordToScalar"
    },
    {
      "id": "PTS-002",
      "description": "ScalarOperations.passwordToScalar - 6 digit with 00 prefix",
      "password": "123456",
      "expected_hex": "3030313233343536",
      "expected_bytes": [48, 48, 49, 50, 51, 52, 53, 54],
      "_note": "6-digit code gets '00' prefix (ASCII 0x30, 0x30)"
    }
  ],
  
  "assertions": [
    {
      "id": "ASSERT-001",
      "description": "All scalars are exactly 32 bytes",
      "field": "scalar.count",
      "equals": 32
    },
    {
      "id": "ASSERT-002",
      "description": "Raw variant preserves UTF-8 bytes at start",
      "field": "raw_variant[0:4]",
      "for_password": "1234",
      "equals_hex": "31323334"
    },
    {
      "id": "ASSERT-003",
      "description": "Salt is UTF-8 encoded",
