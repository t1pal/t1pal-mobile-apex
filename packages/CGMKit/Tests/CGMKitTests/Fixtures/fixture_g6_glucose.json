{
  "_source": "CGMBLEKit GlucoseRxMessage format",
  "_task": "G6-COEX-031",
  "_format": {
    "name": "GlucoseRxMessage (CGMBLEKit compatible)",
    "opcode": "0x31",
    "bytes[0]": "opcode (0x31 = glucoseRx)",
    "bytes[1]": "status",
    "bytes[2-5]": "sequence (UInt32 LE)",
    "bytes[6-9]": "timestamp (UInt32 LE)",
    "bytes[10-11]": "glucose(bits 0-11) + displayOnly(bit 12+) (UInt16 LE)",
    "bytes[12]": "state (UInt8, 0x06 = hasReliableGlucose)",
    "bytes[13]": "trend (Int8)",
    "bytes[14-15]": "CRC16 (placeholder 0x0000)"
  },
  "test_vectors": [
