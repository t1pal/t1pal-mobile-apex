        "sequence": 1,
        "timestamp": 10000,
        "glucoseValue": 120,
        "glucoseIsDisplayOnly": false,
        "state": 6,
        "glucose": 120.0,
        "trend": 0,
        "isValid": true
      },
      "glucose_category": "in_range"
    },
