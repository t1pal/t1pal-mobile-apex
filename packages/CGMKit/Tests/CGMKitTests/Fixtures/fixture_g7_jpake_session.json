      "assertions": [
        { "field": "totalTxBytes", "equals": 355 },
        { "field": "totalRxBytes", "equals": 355 },
        { "field": "totalBytes", "equals": 710 }
      ]
    },
    {
      "id": "JPAKE-SESSION-009",
      "name": "Session rejects out-of-order messages",
      "description": "Protocol enforces correct message ordering",
      "test_cases": [
        { "scenario": "Round2 before Round1", "expected_error": "unexpectedState" },
        { "scenario": "Confirm before Round2", "expected_error": "unexpectedState" },
        { "scenario": "Round1 response when idle", "expected_error": "unexpectedState" }
      ]
    },
    {
