  "_format": {
    "name": "G7GlucoseMessage (Loop-compatible)",
    "opcode": "0x4E",
    "bytes[0]": "opcode (0x4E)",
    "bytes[1]": "reserved",
    "bytes[2-5]": "messageTimestamp (UInt32 LE, sensor time in seconds)",
    "bytes[6-7]": "sequence (UInt16 LE)",
    "bytes[8]": "reserved",
    "bytes[9]": "session indicator (1 = active)",
    "bytes[10-11]": "age (UInt16 LE, seconds since reading)",
    "bytes[12-13]": "glucose (UInt16 LE, mg/dL, 0xFFFF = invalid)",
    "bytes[14]": "algorithmState (0x06=ok, 0x02=warmup, 0x01=stopped, 0x18=expired)",
    "bytes[15]": "trend (Int8 signed, rate * 10, 0x7F = missing)",
    "bytes[16-17]": "predicted (UInt16 LE, 0xFFFF = not available)",
    "bytes[18]": "condition (flags, bit 4 = displayOnly)"
  },
