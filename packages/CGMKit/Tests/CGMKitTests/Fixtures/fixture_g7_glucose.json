  "python_compat": {
    "description": "Python parsing logic for G7 glucose messages",
    "code": "import struct\n\ndef parse_g7_glucose(data: bytes) -> dict:\n    if len(data) < 19 or data[0] != 0x4E:\n        return None\n    msg_ts = struct.unpack('<I', data[2:6])[0]\n    seq = struct.unpack('<H', data[6:8])[0]\n    age = struct.unpack('<H', data[10:12])[0]\n    glucose_raw = struct.unpack('<H', data[12:14])[0]\n    glucose = glucose_raw if glucose_raw > 0 and glucose_raw != 0xFFFF else None\n    algo_state = data[14]\n    trend_raw = struct.unpack('b', bytes([data[15]]))[0]\n    trend = trend_raw / 10.0 if trend_raw != 0x7F else None\n    predicted = struct.unpack('<H', data[16:18])[0]\n    predicted = predicted if predicted != 0xFFFF else None\n    condition = data[18]\n    return {\n        'messageTimestamp': msg_ts,\n        'glucoseTimestamp': msg_ts - age,\n        'sequence': seq,\n        'age': age,\n        'glucose': glucose,\n        'algorithmState': algo_state,\n        'trend': trend,\n        'predicted': predicted,\n        'glucoseIsDisplayOnly': (condition & 0x10) != 0\n    }\n\ndef parse_g7_backfill(data: bytes) -> dict:\n    if len(data) < 9:\n        return None\n    ts_bytes = data[0:3] + b'\\x00'\n    timestamp = struct.unpack('<I', ts_bytes)[0]\n    glucose = struct.unpack('<H', data[3:5])[0]\n    algo_state = data[5]\n    trend_raw = struct.unpack('b', bytes([data[6]]))[0]\n    trend = trend_raw / 10.0 if trend_raw != 0x7F else None\n    condition = data[8]\n    return {\n        'timestamp': timestamp,\n        'glucose': glucose,\n        'algorithmState': algo_state,\n        'trend': trend,\n        'glucoseIsDisplayOnly': (condition & 0x10) != 0,\n        'hasReliableGlucose': algo_state == 0x06\n    }"
  }
