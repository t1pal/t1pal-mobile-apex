{
  "_source": "CGMBLEKit GlucoseRxMessageTests.swift (Loop/Trio)",
  "_task": "G6-SYNTH-007",
  "_description": "Test vectors for Dexcom G5 glucose messages (opcode 0x31)",
  "_format": {
    "name": "GlucoseRxMessage (G5)",
    "opcode": "0x31",
    "length": 16,
    "structure": "31 SS NNNNNNNN TTTTTTTT GGGG ST TR CC CC",
    "fields": {
      "byte[0]": "opcode (0x31 = glucoseRx)",
      "byte[1]": "status",
      "bytes[2-5]": "sequence (UInt32 LE)",
      "bytes[6-9]": "timestamp (UInt32 LE)",
      "bytes[10-11]": "glucose: bits 0-11 = value, bits 12-15 = displayOnly flag",
      "byte[12]": "state",
      "byte[13]": "trend (Int8, signed)",
      "bytes[14-15]": "CRC16"
    },
    "displayOnly_extraction": "glucoseIsDisplayOnly = (glucoseBytes & 0xF000) > 0",
    "glucose_extraction": "glucose = glucoseBytes & 0x0FFF"
  },
  "test_vectors": [
