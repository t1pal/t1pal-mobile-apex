  "state_values": {
    "description": "Known sensor state values",
    "values": {
      "0": "None",
      "1": "Stopped",
      "2": "Warmup",
      "3": "ExcessNoise",
      "4": "NeedsFirstCalibration",
      "5": "NeedsSecondCalibration",
      "6": "OK",
      "7": "NeedsCalibration",
      "8": "CalibrationError1",
      "9": "CalibrationError2",
      "10": "CalibrationLinearityFitFailure",
      "11": "SensorFailedDueToCountsAberration",
      "12": "SensorFailedDueToResidualAberration",
      "128": "Reserved for extension"
    }
  },
  "python_compat": {
    "description": "Python parsing logic for G5 glucose messages",
    "code": "import struct\n\ndef parse_g5_glucose(data: bytes) -> dict:\n    \"\"\"Parse G5 GlucoseRxMessage from raw bytes.\"\"\"\n    if len(data) < 14 or data[0] != 0x31:\n        raise ValueError('Invalid G5 glucose message')\n    \n    status = data[1]\n    sequence = struct.unpack('<I', data[2:6])[0]\n    timestamp = struct.unpack('<I', data[6:10])[0]\n    glucose_bytes = struct.unpack('<H', data[10:12])[0]\n    \n    display_only = (glucose_bytes & 0xF000) > 0\n    glucose = glucose_bytes & 0x0FFF\n    state = data[12]\n    trend = struct.unpack('<b', data[13:14])[0]  # signed int8\n    \n    return {\n        'status': status,\n        'sequence': sequence,\n        'timestamp': timestamp,\n        'glucoseIsDisplayOnly': display_only,\n        'glucose': glucose,\n        'state': state,\n        'trend': trend\n    }"
  }
}
