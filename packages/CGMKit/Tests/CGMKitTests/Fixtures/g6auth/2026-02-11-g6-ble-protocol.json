  "testCases": {
    "connection": [
      {
        "name": "scan_and_discover",
        "description": "Scan for G6 transmitter by advertisement UUID",
        "steps": [
          {"action": "scan", "filter": "0xFEBC"},
          {"action": "verify", "field": "localName", "pattern": "Dexcom.*"}
        ]
      },
      {
        "name": "connect_and_discover",
        "description": "Connect and discover CGM service",
        "steps": [
          {"action": "connect"},
          {"action": "discoverServices"},
          {"action": "verify", "serviceUUID": "F8083532-849E-531C-C594-30F1F86A4EA5"}
        ]
      }
    ],
    "authentication": [
      {
        "name": "auth_success",
        "description": "Successful authentication flow",
        "transmitterId": "80AB12",
        "steps": [
          {"action": "subscribe", "characteristic": "authentication"},
          {"action": "write", "characteristic": "authentication", "data": "01{token}02"},
          {"action": "expect", "opcode": "0x03", "fields": ["tokenHash", "challenge"]},
          {"action": "write", "characteristic": "authentication", "data": "04{challengeHash}"},
          {"action": "expect", "opcode": "0x05", "authenticated": true}
        ]
      },
      {
        "name": "auth_failure_wrong_id",
        "description": "Authentication fails with wrong transmitter ID",
        "transmitterId": "WRONG1",
        "expectedResult": {
          "opcode": "0x05",
          "authenticated": false,
          "bonded": false
        }
      }
    ],
    "glucoseReading": [
