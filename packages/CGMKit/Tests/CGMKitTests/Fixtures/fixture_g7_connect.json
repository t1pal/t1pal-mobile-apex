  "jpake_protocol": {
    "description": "J-PAKE (Password Authenticated Key Exchange by Juggling) per RFC 8236",
    "curve": "P-256",
    "password": "4-digit sensor code",
    "rounds": [
      {
        "round": 1,
        "description": "Exchange g^x1, g^x2 with zero-knowledge proofs",
        "client_sends": ["g^x1 (32 bytes)", "g^x2 (32 bytes)", "ZKP1 (80 bytes)", "ZKP2 (80 bytes)"],
        "server_responds": ["g^x3 (32 bytes)", "g^x4 (32 bytes)", "ZKP3 (80 bytes)", "ZKP4 (80 bytes)"]
      },
      {
        "round": 2,
        "description": "Compute A = g^((x1+x3+x4)*x2*s) where s is password",
        "client_sends": ["A (32 bytes)", "ZKP_A (80 bytes)"],
        "server_responds": ["B (32 bytes)", "ZKP_B (80 bytes)"]
      },
      {
        "round": 3,
        "description": "Key confirmation - exchange confirmation hashes",
        "client_sends": ["confirmHash (16 bytes)"],
        "server_responds": ["confirmHash (16 bytes)"]
      }
    ],
    "zkp_structure": {
      "commitment": "32 bytes",
      "challenge": "16 bytes",
      "response": "32 bytes",
      "total": "80 bytes"
    }
  },

